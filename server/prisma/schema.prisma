generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  fullName  String?
  avatarUrl String?
  bio       String?

  emailNotifications Boolean @default(true)
  inAppNotifications Boolean @default(true)
  theme              String  @default("light")

  isOnline Boolean   @default(false)
  lastSeen DateTime?

  activeCompanyId Int?
  activeCompany   Company? @relation("ActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)

  ownedCompanies     Company[]           @relation("CompanyOwner")
  memberships        Membership[]
  projectMemberships ProjectMembership[]

  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]

  createdTasks  Task[] @relation("CreatedTasks")
  assignedTasks Task[] @relation("AssignedTasks")

  notifications Notification[]
  messages      Message[]

  comments       Comment[]
  attachments    Attachment[]
  uploadedFiles  MessageAttachment[]
  channelMembers ChannelMember[]
  activityLogs   ActivityLog[]
  taskActivities TaskActivity[]
  watchedTasks   TaskWatcher[]

  createdEvents   Event[]         @relation("CreatedEvents")
  attendingEvents EventAttendee[]

  companyInvitesSent CompanyInvite[] @relation("CompanyInvitedBy")
  projectInvitesSent ProjectInvite[] @relation("ProjectInvitedBy")

  reactions   MessageReaction[]
  messageSeen MessageSeen[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  reviewedJoinRequests CompanyJoinRequest[] @relation("ReviewedJoinRequests")

  acceptedCompanyInvites CompanyInvite[] @relation("AcceptedCompanyInvites")

  acceptedProjectInvites ProjectInvite[] @relation("AcceptedProjectInvites")

  @@index([activeCompanyId])
  @@index([email])
}

model RefreshToken {
  id Int @id @default(autoincrement())

  token String @unique

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id Int @id @default(autoincrement())

  email String
  token String @unique

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
}

model Company {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  logoUrl String?

  inviteCode          String?   @unique
  inviteCodeExpiresAt DateTime?

  ownerId Int
  owner   User @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  activeUsers User[] @relation("ActiveCompany")

  members Membership[]

  workspaces Workspace[]
  projects   Project[]
  channels   Channel[]

  tasks Task[]

  joinRequests CompanyJoinRequest[]
  invites      CompanyInvite[]

  activityLogs  ActivityLog[]
  notifications Notification[]
  events        Event[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
}

model Membership {
  id Int @id @default(autoincrement())

  userId    Int
  companyId Int

  role Role @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model CompanyJoinRequest {
  id Int @id @default(autoincrement())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  email String

  status JoinRequestStatus @default(PENDING)

  reviewedById Int?
  reviewedBy   User?     @relation("ReviewedJoinRequests", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}

model CompanyInvite {
  id Int @id @default(autoincrement())

  email String

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invitedById Int
  invitedBy   User @relation("CompanyInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  role Role @default(MEMBER)

  token String @unique

  status InviteStatus @default(PENDING)

  expiresAt DateTime

  acceptedById Int?
  acceptedBy   User? @relation("AcceptedCompanyInvites", fields: [acceptedById], references: [id], onDelete: SetNull)

  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}

model Workspace {
  id   Int    @id @default(autoincrement())
  name String

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
}

model Project {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  color String @default("#6366f1")

  inviteCode          String?   @unique
  inviteCodeExpiresAt DateTime?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  workspaceId Int?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  tasks    Task[]
  channels Channel[]
  labels   Label[]

  memberships ProjectMembership[]
  invites     ProjectInvite[]
  events      Event[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([workspaceId])
  @@index([name])
}

model ProjectMembership {
  id Int @id @default(autoincrement())

  userId    Int
  projectId Int

  role Role @default(MEMBER)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
}

model ProjectInvite {
  id Int @id @default(autoincrement())

  email String

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  invitedById Int
  invitedBy   User @relation("ProjectInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  role Role @default(MEMBER)

  token String @unique

  status InviteStatus @default(PENDING)

  expiresAt DateTime

  acceptedById Int?
  acceptedBy   User? @relation("AcceptedProjectInvites", fields: [acceptedById], references: [id], onDelete: SetNull)

  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([email])
}

model Task {
  id Int @id @default(autoincrement())

  code String @unique

  title       String
  description String?

  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(MEDIUM)

  dueDate   DateTime?
  startDate DateTime?

  position Int?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId Int?
  assignee   User? @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy   User @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)

  comments    Comment[]
  attachments Attachment[]
  labels      TaskLabel[]

  checklists TaskChecklist[]
  activities TaskActivity[]
  watchers   TaskWatcher[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([title])
  @@index([status])
}

model TaskChecklist {
  id Int @id @default(autoincrement())

  content   String
  completed Boolean @default(false)

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model TaskActivity {
  id Int @id @default(autoincrement())

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  action String

  oldValue String?
  newValue String?

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
}

model TaskWatcher {
  taskId Int
  userId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([taskId, userId])
}

model Comment {
  id      Int    @id @default(autoincrement())
  content String

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([userId])
}

model Attachment {
  id       Int     @id @default(autoincrement())
  fileUrl  String
  fileName String?
  fileType String?

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById Int
  uploadedBy   User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([taskId])
}

model Label {
  id    Int     @id @default(autoincrement())
  name  String
  color String?

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks TaskLabel[]

  @@index([projectId])
}

model TaskLabel {
  taskId  Int
  labelId Int

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Notification {
  id Int @id @default(autoincrement())

  type NotificationType

  title   String?
  content String

  entityId   Int?
  entityType String?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companyId])
}

model Channel {
  id   Int    @id @default(autoincrement())
  name String

  type ChannelType @default(PUBLIC)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  messages Message[]
  members  ChannelMember[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([projectId])
}

model ChannelMember {
  id Int @id @default(autoincrement())

  channelId Int
  userId    Int

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id Int @id @default(autoincrement())

  content String

  channelId Int
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  senderId Int
  sender   User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  reactions   MessageReaction[]
  attachments MessageAttachment[]
  seenBy      MessageSeen[]

  parentId Int?
  parent   Message? @relation("Thread", fields: [parentId], references: [id], onDelete: SetNull)

  replies Message[] @relation("Thread")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([channelId])
  @@index([senderId])
}

model MessageAttachment {
  id Int @id @default(autoincrement())

  messageId Int
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  uploadedById Int
  uploadedBy   User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  fileUrl  String
  fileName String
  fileType String?

  createdAt DateTime @default(now())

  @@index([messageId])
}

model MessageReaction {
  id Int @id @default(autoincrement())

  emoji String

  messageId Int
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model MessageSeen {
  id Int @id @default(autoincrement())

  messageId Int
  userId    Int

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  seenAt DateTime @default(now())

  @@unique([messageId, userId])
}

model Event {
  id Int @id @default(autoincrement())

  title       String
  description String?

  startTime DateTime
  endTime   DateTime

  location String?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy   User @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: Cascade)

  attendees EventAttendee[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([projectId])
}

model EventAttendee {
  id Int @id @default(autoincrement())

  eventId Int
  userId  Int

  status AttendanceStatus @default(PENDING)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model ActivityLog {
  id Int @id @default(autoincrement())

  action String

  entityId   Int?
  entityType String?

  metadata Json?

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum AttendanceStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  TASK_ASSIGNED
  COMMENT
  MENTION
  DEADLINE
  MESSAGE
  COMPANY_INVITE
  PROJECT_INVITE
  EVENT_INVITE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  PUBLIC
  PRIVATE
  DIRECT
}
